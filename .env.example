# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=domain_system
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_which_must_be_at_least_256_bits_long_for_hs256_security
JWT_ACCESS_EXPIRATION_SEC=1800
JWT_REFRESH_EXPIRATION_SEC=172800

# Storage Directory
FILE_UPLOAD_DIR=./uploads
